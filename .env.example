# Core mix tuning
TRANSITION_LENGTH=30
TRANSITION_WINDOW=64
LUFS_TARGET=-14
SAMPLE_RATE=44100

# Feature toggles
ENABLE_AGENTIC_DURATION=false

# Paths
CACHE_DIR=./data/cache/stream
TEMP_DIR=./temp_audio

# Server
HOST=0.0.0.0
PORT=5005

# YouTube download
YTDLP_EXTRACTOR_ARGS=youtube:player_client=android
DOWNLOAD_TIMEOUT_SEC=120
