# Core mix tuning
TRANSITION_LENGTH=30
TRANSITION_WINDOW=64
LUFS_TARGET=-14
SAMPLE_RATE=44100

# Feature toggles
ENABLE_AGENTIC_DURATION=false

# Paths
CACHE_DIR=./data/cache/stream
TEMP_DIR=./temp_audio

# Server
HOST=0.0.0.0
PORT=5005            # local dev; the container/HF Spaces default is 7860

# YouTube download
YTDLP_EXTRACTOR_ARGS=youtube:player_client=android
DOWNLOAD_TIMEOUT_SEC=120
# Netscape cookies.txt PATH for yt-dlp (datacenter-IP bot mitigation). In a container
# the entrypoint can instead take the cookies CONTENTS from the YT_COOKIES secret.
YT_COOKIES_FILE=

# Abuse / resource caps (memory-efficiency + security)
ALLOW_YOUTUBE=true
MAX_PLAYLIST_TRACKS=12
PER_TRACK_CAP_SEC=150
MAX_DOWNLOAD_MB=60
SESSION_TTL_SEC=1800
MAX_SESSIONS=24
RATE_LIMIT=30 per hour
